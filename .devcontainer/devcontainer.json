{
  "name": "de zoomcamp",
  "build": {
    "dockerfile": "../Dockerfile",
    "context": ".."
  },
  "runArgs": [
    "--network=dev-shared"
  ],
  "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
  "remoteUser": "vscode",
  "mounts": [
    "source=/var/run/docker.sock,target=/var/run/docker.sock,type=bind"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-toolsai.jupyter",
        "ms-python.vscode-pylance"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "jupyter.notebookFileRoot": "/workspaces/${localWorkspaceFolderBasename}"
      }
    }
  },
  "forwardPorts": [8888],
  "postCreateCommand": "git config --global user.name 'Nont' && git config --global user.email 'nontavit@gmail.com' && python -m ipykernel install --user --name de-zoomcamp --display-name 'Python (de-zoomcamp)'"
}